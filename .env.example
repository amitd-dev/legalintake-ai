# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...            # required. Server-side only — never exposed to the client.
ANTHROPIC_MODEL=claude-sonnet-4-6       # optional override

# --- Firm configuration ---
FIRM_NAME=Hartwell & Vance LLP
FIRM_PRACTICE_AREAS=personal injury,family law,estate planning,business law
FIRM_ATTORNEYS=Rachel Hartwell:personal injury|employment law,Marcus Vance:business law,Priya Natarajan:family law|estate planning

# --- Database (DigitalOcean Managed Postgres) ---
# DO control panel -> your DB cluster -> Connection Details -> Connection string (sslmode=require)
DATABASE_URL=postgresql://doadmin:PASSWORD@host:25060/defaultdb?sslmode=require

# --- One-time schema migration over HTTP (Phase 2+) ---
MIGRATE_TOKEN=choose-a-long-random-string

# --- Google Calendar (Phase 3, service account) ---
# Paste the full service-account JSON as a single line, and share the target calendar
# with the service account's client_email (with "Make changes to events" permission).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_CALENDAR_ID=primary-or-calendar-id@group.calendar.google.com

# --- Escalation notifications (Phase 5, optional) ---
RESEND_API_KEY=
ESCALATION_EMAIL=partner@firm.com
